---
/**
 * Footer.astro — 页脚
 */
import { getProfile } from '../utils/userData';

const profile = getProfile();
const year = new Date().getFullYear();
---

<footer style="margin-top: 3rem; border-top: 1px solid var(--color-border); background-color: var(--color-bg);">
	<div class="mx-auto max-w-[1400px] px-4 py-8 text-center lg:px-8">
		<p style="font-size: 0.875rem; color: var(--color-text-secondary);">
			&copy; {year} {profile.name}. 保留所有权利。
		</p>
	</div>
</footer>
