---
/**
 * Calendar.astro — 日历组件（移植自 Firefly）
 * 核心逻辑来自 Firefly/src/components/widget/Calendar.astro
 * 修改：数据源 → user/posts，颜色 → CSS 变量
 */
import { getCalendarData } from '../utils/userData';

const calendarData = getCalendarData();
const postUrlPrefix = '/blog/';

// 月份名称
const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];

// 星期名称
const weekDays = ['日', '一', '二', '三', '四', '五', '六'];

// 热力图周数文本模板
const heatmapWeekTemplate = '{month}月第{week}周: {count}篇';
---

<div class="card" id="calendar-widget">
  <div class="calendar-container">
    <!-- 月份导航 -->
    <div class="flex justify-between items-center mb-2">
      <button id="prev-month-btn" class="cal-nav-btn" aria-label="上个月">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
      </button>
      <div id="current-month-display" class="text-sm font-bold cursor-pointer select-none transition-colors" style="color: var(--color-text);"></div>
      <div class="flex gap-1">
        <button id="reset-month-btn" class="cal-nav-btn" aria-label="回到今天">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.885.666A5.002 5.002 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd" /></svg>
        </button>
        <button id="next-month-btn" class="cal-nav-btn" aria-label="下个月">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
        </button>
      </div>
    </div>

    <!-- 日历视图 -->
    <div id="calendar-view-container">
      <div class="weekdays grid grid-cols-7 gap-1 mb-2">
        {weekDays.map(day => (
          <div class="text-center text-xs font-medium" style="color: var(--color-text-secondary);">{day}</div>
        ))}
      </div>
      <div class="calendar-grid grid grid-cols-7 gap-1 pb-1" id="calendar-grid"></div>
    </div>

    <!-- 年度文章热力图 -->
    <div id="heatmap-container" class="mb-2" style="display: none;">
      <div class="heatmap-months grid gap-0.5 mb-1" id="heatmap-months" style="grid-template-columns: repeat(12, 1fr);"></div>
      <div class="heatmap-grid grid" id="heatmap-grid" style="grid-template-columns: repeat(12, 1fr); grid-template-rows: repeat(4, 1fr); row-gap: 0.125rem;"></div>
    </div>

    <!-- 月份选择视图 -->
    <div id="month-view-container" class="grid grid-cols-3 gap-2" style="display: none;"></div>

    <!-- 年份选择视图 -->
    <div id="year-view-container" class="grid grid-cols-3 gap-2" style="display: none;"></div>

    <!-- 文章列表 -->
    <div id="calendar-posts" class="mt-3">
      <div class="border-t mb-2" id="calendar-posts-divider" style="display: none; border-color: var(--color-border);"></div>
      <div class="flex flex-col gap-1 max-h-48 overflow-y-auto" id="calendar-posts-list"></div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ calendarData, postUrlPrefix, monthNames, weekDays, heatmapWeekTemplate }}>
  // === State ===
  let displayYear = new Date().getFullYear();
  let displayMonth = new Date().getMonth();
  let currentView = 'day'; // 'day' | 'month' | 'year'
  let postDateMap = {};
  let allPostsData = calendarData || [];
  let availableYears = [];

  // === Init ===
  (function initCalendar() {
    // Build postDateMap and availableYears
    postDateMap = {};
    const yearsSet = new Set();
    allPostsData.forEach(function(post) {
      const date = new Date(post.published);
      const dateKey = date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0') + '-' + String(date.getDate()).padStart(2, '0');
      if (!postDateMap[dateKey]) postDateMap[dateKey] = [];
      postDateMap[dateKey].push({ id: post.id, title: post.title, published: post.published });
      yearsSet.add(date.getFullYear());
    });
    availableYears = Array.from(yearsSet).sort(function(a, b) { return b - a; });

    renderCalendar();

    // Bind events
    var prevBtn = document.getElementById('prev-month-btn');
    var nextBtn = document.getElementById('next-month-btn');
    var resetBtn = document.getElementById('reset-month-btn');
    var navDisplay = document.getElementById('current-month-display');

    if (prevBtn) prevBtn.onclick = function() { changeMonth(-1); };
    if (nextBtn) nextBtn.onclick = function() { changeMonth(1); };
    if (resetBtn) resetBtn.onclick = function() { resetToToday(); };
    if (navDisplay) navDisplay.onclick = function() {
      if (currentView === 'day') currentView = 'month';
      else if (currentView === 'month') currentView = 'year';
      renderCalendar();
    };
  })();

  // === Render Calendar ===
  function renderCalendar() {
    var container = document.getElementById('calendar-view-container');
    var monthContainer = document.getElementById('month-view-container');
    var yearContainer = document.getElementById('year-view-container');
    var postsContainer = document.getElementById('calendar-posts');

    if (container) container.style.display = currentView === 'day' ? 'block' : 'none';
    if (monthContainer) monthContainer.style.display = currentView === 'month' ? 'grid' : 'none';
    if (yearContainer) yearContainer.style.display = currentView === 'year' ? 'grid' : 'none';
    if (postsContainer) postsContainer.style.display = currentView === 'day' ? 'block' : 'none';

    updateHeader();

    if (currentView === 'day') renderDayView();
    else if (currentView === 'month') renderMonthView();
    else if (currentView === 'year') renderYearView();

    renderHeatmap();
  }

  function updateHeader() {
    var navDisplay = document.getElementById('current-month-display');
    var resetBtn = document.getElementById('reset-month-btn');
    var prevBtn = document.getElementById('prev-month-btn');
    var nextBtn = document.getElementById('next-month-btn');

    if (navDisplay) {
      if (currentView === 'day') {
        navDisplay.textContent = displayYear + '年' + monthNames[displayMonth];
      } else if (currentView === 'month') {
        navDisplay.textContent = displayYear + '年';
      } else if (currentView === 'year') {
        navDisplay.textContent = '年份';
      }
    }

    if (resetBtn) {
      var now = new Date();
      var isCurrent = displayYear === now.getFullYear() && displayMonth === now.getMonth();
      resetBtn.style.display = (currentView === 'day' && isCurrent) ? 'none' : 'flex';
    }

    if (prevBtn) prevBtn.style.visibility = currentView === 'year' ? 'hidden' : 'visible';
    if (nextBtn) nextBtn.style.visibility = currentView === 'year' ? 'hidden' : 'visible';
  }

  // === Day View ===
  function renderDayView() {
    var now = new Date();
    var currentYear = displayYear;
    var currentMonth = displayMonth;
    var currentDate = now.getDate();
    var isCurrentMonth = currentYear === now.getFullYear() && currentMonth === now.getMonth();

    var firstDayOfMonth = new Date(currentYear, currentMonth, 1).getDay();
    var daysInMonth = new Date(currentYear, currentMonth + 1, 0).getDate();

    var calendarGrid = document.getElementById('calendar-grid');
    if (!calendarGrid) return;

    var calendarDays = [];

    // Empty cells before first day
    for (var i = 0; i < firstDayOfMonth; i++) {
      calendarDays.push({ day: null, hasPost: false, count: 0, dateKey: '' });
    }

    // Each day
    for (var day = 1; day <= daysInMonth; day++) {
      var dateKey = currentYear + '-' + String(currentMonth + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
      var posts = postDateMap[dateKey] || [];
      calendarDays.push({ day: day, hasPost: posts.length > 0, count: posts.length, dateKey: dateKey });
    }

    calendarGrid.innerHTML = calendarDays.map(function(item) {
      var day = item.day, hasPost = item.hasPost, count = item.count, dateKey = item.dateKey;
      var isToday = day === currentDate && isCurrentMonth;
      var classes = ['calendar-day', 'aspect-square', 'flex', 'items-center', 'justify-center', 'rounded', 'text-sm', 'relative', 'cursor-pointer'];

      if (!day) {
        // empty
      } else if (isToday) {
        classes.push('ring-2');
        classes.push('font-bold');
      } else if (hasPost) {
        classes.push('font-bold');
      }

      var style = '';
      if (!day) {
        style = 'color: var(--color-text-secondary); opacity: 0.3;';
      } else if (isToday) {
        style = 'color: var(--color-primary); --tw-ring-color: var(--color-primary);';
      } else if (hasPost) {
        style = 'color: var(--color-text);';
      } else {
        style = 'color: var(--color-text);';
      }

      var dot = hasPost ? '<span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="background-color: var(--color-primary);"></span>' : '';
      var countBadge = hasPost && count > 1 ? '<span class="absolute top-0 right-0 text-[10px] font-bold" style="color: var(--color-primary);">' + count + '</span>' : '';

      return '<div class="' + classes.join(' ') + '" style="' + style + '" data-date="' + dateKey + '" data-has-post="' + hasPost + '">' + (day || '') + dot + countBadge + '</div>';
    }).join('');

    // Monthly posts list
    var currentMonthPosts = allPostsData.filter(function(post) {
      var date = new Date(post.published);
      return date.getFullYear() === currentYear && date.getMonth() === currentMonth;
    });

    showMonthlyPosts(currentMonthPosts);
    setupClickHandlers(currentMonthPosts);
  }

  // === Month View ===
  function renderMonthView() {
    var container = document.getElementById('month-view-container');
    if (!container) return;

    var monthsWithPosts = new Set();
    allPostsData.forEach(function(post) {
      var date = new Date(post.published);
      if (date.getFullYear() === displayYear) monthsWithPosts.add(date.getMonth());
    });

    container.innerHTML = monthNames.map(function(name, index) {
      var isCurrent = index === displayMonth;
      var hasPost = monthsWithPosts.has(index);
      var classes = ['p-2', 'text-center', 'text-sm', 'rounded', 'cursor-pointer', 'transition-colors', 'relative'];
      if (isCurrent) {
        classes.push('font-bold');
      }
      var style = isCurrent
        ? 'color: var(--color-primary); background-color: var(--color-primary-light);'
        : 'color: var(--color-text);';
      var dot = hasPost ? '<span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="background-color: var(--color-primary);"></span>' : '';
      return '<div class="' + classes.join(' ') + '" style="' + style + '" data-month="' + index + '">' + name + dot + '</div>';
    }).join('');

    container.querySelectorAll('[data-month]').forEach(function(el) {
      el.addEventListener('click', function() {
        displayMonth = parseInt(el.getAttribute('data-month'));
        currentView = 'day';
        renderCalendar();
      });
    });
  }

  // === Year View ===
  function renderYearView() {
    var container = document.getElementById('year-view-container');
    if (!container) return;

    container.innerHTML = availableYears.map(function(year) {
      var isCurrent = year === displayYear;
      var classes = ['p-2', 'text-center', 'text-sm', 'rounded', 'cursor-pointer', 'transition-colors', 'relative'];
      if (isCurrent) classes.push('font-bold');
      var style = isCurrent
        ? 'color: var(--color-primary); background-color: var(--color-primary-light);'
        : 'color: var(--color-text);';
      return '<div class="' + classes.join(' ') + '" style="' + style + '" data-year="' + year + '">' + year + '<span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="background-color: var(--color-primary);"></span></div>';
    }).join('');

    container.querySelectorAll('[data-year]').forEach(function(el) {
      el.addEventListener('click', function() {
        displayYear = parseInt(el.getAttribute('data-year'));
        currentView = 'month';
        renderCalendar();
      });
    });
  }

  // === Heatmap ===
  function renderHeatmap() {
    var container = document.getElementById('heatmap-container');
    var monthsEl = document.getElementById('heatmap-months');
    var gridEl = document.getElementById('heatmap-grid');
    if (!container || !monthsEl || !gridEl) return;

    container.style.display = currentView === 'day' ? 'block' : 'none';
    if (currentView !== 'day') return;

    // Month labels
    monthsEl.innerHTML = Array.from({length: 12}, function(_, i) {
      return '<span class="text-[10px] text-center" style="color: var(--color-text-secondary);">' + (i + 1) + '</span>';
    }).join('');

    // Build heatmap data
    var heatmapData = Array.from({ length: 12 }, function() { return [0, 0, 0, 0]; });
    allPostsData.forEach(function(post) {
      var date = new Date(post.published);
      if (date.getFullYear() !== displayYear) return;
      var month = date.getMonth();
      var day = date.getDate();
      var week = Math.min(Math.floor((day - 1) / 7), 3);
      heatmapData[month][week]++;
    });

    var opacityLevels = [0, 0.45, 0.65, 0.85, 1];
    var cellsHtml = '';
    for (var week = 0; week < 4; week++) {
      for (var month = 0; month < 12; month++) {
        var count = heatmapData[month][week];
        var level = Math.min(count, 4);
        var bgStyle = count === 0
          ? 'background-color: var(--color-primary-light)'
          : 'background-color: var(--color-primary); opacity: ' + opacityLevels[level];
        var tooltip = heatmapWeekTemplate
          .replace('{month}', month + 1)
          .replace('{week}', week + 1)
          .replace('{count}', count);
        cellsHtml += '<div class="heatmap-cell rounded-sm" style="' + bgStyle + '" data-tooltip="' + tooltip + '" data-month="' + month + '"></div>';
      }
    }
    gridEl.innerHTML = cellsHtml;

    // Click to navigate month
    gridEl.querySelectorAll('.heatmap-cell[data-month]').forEach(function(cell) {
      cell.addEventListener('click', function() {
        displayMonth = parseInt(cell.getAttribute('data-month'));
        currentView = 'day';
        renderCalendar();
      });
    });

    // Tooltip
    var tooltipEl = document.getElementById('heatmap-tooltip');
    if (!tooltipEl) {
      tooltipEl = document.createElement('div');
      tooltipEl.id = 'heatmap-tooltip';
      Object.assign(tooltipEl.style, {
        position: 'fixed', padding: '4px 8px', borderRadius: '6px',
        fontSize: '0.75rem', lineHeight: '1.2',
        background: 'rgba(0,0,0,0.8)', color: '#fff',
        boxShadow: '0 2px 8px rgba(0,0,0,0.15)',
        pointerEvents: 'none', opacity: '0',
        transition: 'opacity 0.15s ease', zIndex: '9999', whiteSpace: 'nowrap',
      });
      document.body.appendChild(tooltipEl);
    }
    gridEl.querySelectorAll('.heatmap-cell[data-tooltip]').forEach(function(cell) {
      cell.addEventListener('mouseenter', function() {
        tooltipEl.textContent = cell.getAttribute('data-tooltip');
        tooltipEl.style.opacity = '1';
        var rect = cell.getBoundingClientRect();
        tooltipEl.style.left = rect.left + rect.width / 2 - tooltipEl.offsetWidth / 2 + 'px';
        tooltipEl.style.top = rect.top - tooltipEl.offsetHeight - 6 + 'px';
      });
      cell.addEventListener('mouseleave', function() {
        tooltipEl.style.opacity = '0';
      });
    });
  }

  // === Show Monthly Posts ===
  function showMonthlyPosts(currentMonthPosts) {
    var postsWrapper = document.getElementById('calendar-posts');
    var postsList = document.getElementById('calendar-posts-list');
    var divider = document.getElementById('calendar-posts-divider');

    if (postsWrapper) postsWrapper.style.display = currentMonthPosts.length > 0 ? 'block' : 'none';
    if (postsList) {
      postsList.innerHTML = currentMonthPosts.map(function(post) {
        var date = new Date(post.published);
        var dateStr = (date.getMonth() + 1) + '-' + date.getDate();
        return '<a href="' + postUrlPrefix + post.id + '/" class="flex justify-between items-center text-sm no-underline transition-colors px-2 py-1 rounded" style="color: var(--color-text);" onmouseenter="this.style.color=\'var(--color-primary)\';this.style.backgroundColor=\'var(--color-primary-light)\'" onmouseleave="this.style.color=\'var(--color-text)\';this.style.backgroundColor=\'transparent\'">' +
          '<span class="truncate">' + post.title + '</span>' +
          '<span class="text-xs ml-2 whitespace-nowrap" style="color: var(--color-text-secondary);">' + dateStr + '</span>' +
          '</a>';
      }).join('');
      if (divider) divider.style.display = currentMonthPosts.length > 0 ? 'block' : 'none';
    }
  }

  // === Click Handlers for Calendar Days ===
  function setupClickHandlers(currentMonthPosts) {
    var postsWrapper = document.getElementById('calendar-posts');
    var calendarDays = document.querySelectorAll('.calendar-day[data-date]');
    var postsList = document.getElementById('calendar-posts-list');
    var divider = document.getElementById('calendar-posts-divider');

    var currentSelectedDay = null;

    calendarDays.forEach(function(dayElement) {
      dayElement.addEventListener('click', function() {
        var dateKey = dayElement.getAttribute('data-date');
        var hasPost = dayElement.getAttribute('data-has-post') === 'true';

        if (!hasPost || !dateKey) return;

        if (currentSelectedDay === dayElement) {
          dayElement.classList.remove('calendar-day-selected');
          currentSelectedDay = null;
          showMonthlyPosts(currentMonthPosts);
          return;
        }

        if (currentSelectedDay) currentSelectedDay.classList.remove('calendar-day-selected');

        dayElement.classList.add('calendar-day-selected');
        currentSelectedDay = dayElement;

        var posts = postDateMap[dateKey] || [];
        if (posts.length > 0 && postsList) {
          if (postsWrapper) postsWrapper.style.display = 'block';
          postsList.innerHTML = posts.map(function(post) {
            var date = new Date(post.published);
            var dateStr = (date.getMonth() + 1) + '-' + date.getDate();
            return '<a href="' + postUrlPrefix + post.id + '/" class="flex justify-between items-center text-sm no-underline transition-colors px-2 py-1 rounded" style="color: var(--color-text);" onmouseenter="this.style.color=\'var(--color-primary)\';this.style.backgroundColor=\'var(--color-primary-light)\'" onmouseleave="this.style.color=\'var(--color-text)\';this.style.backgroundColor=\'transparent\'">' +
              '<span class="truncate">' + post.title + '</span>' +
              '<span class="text-xs ml-2 whitespace-nowrap" style="color: var(--color-text-secondary);">' + dateStr + '</span>' +
              '</a>';
          }).join('');
          if (divider) divider.style.display = 'block';
        }
      });
    });
  }

  // === Navigation ===
  function changeMonth(delta) {
    if (currentView === 'day') {
      displayMonth += delta;
      if (displayMonth > 11) { displayMonth = 0; displayYear++; }
      else if (displayMonth < 0) { displayMonth = 11; displayYear--; }
    } else if (currentView === 'month') {
      displayYear += delta;
    }
    renderCalendar();
  }

  function resetToToday() {
    var now = new Date();
    displayYear = now.getFullYear();
    displayMonth = now.getMonth();
    currentView = 'day';
    renderCalendar();
  }
</script>

<style>
  .cal-nav-btn {
    display: flex; align-items: center; justify-content: center;
    width: 2rem; height: 2rem; border-radius: 0.5rem;
    transition: background-color 0.15s, color 0.15s;
    color: var(--color-text-secondary);
    background: transparent; border: none; cursor: pointer;
  }
  .cal-nav-btn:hover {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }

  /* Calendar day — :global() because grid is generated by JS */
  :global(.calendar-day) {
    transition: all 0.2s ease;
    min-height: 32px;
  }
  :global(.calendar-day[data-has-post="true"]:hover) {
    transform: translateY(-2px);
    background-color: var(--color-primary-light);
  }
  :global(.calendar-day-selected) {
    background-color: var(--color-primary-light) !important;
    border-radius: 0.25rem;
  }

  /* Heatmap cell */
  :global(.heatmap-cell) {
    cursor: pointer;
    min-width: 0;
    width: 85%;
    aspect-ratio: 1;
    margin: auto;
    transition: box-shadow 0.15s ease;
  }
  :global(.heatmap-cell:hover) {
    box-shadow: 0 0 1px 1.5px var(--color-primary);
  }
</style>
