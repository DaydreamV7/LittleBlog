---
/**
 * TableOfContents.astro — Firefly 风格文章目录
 * 左侧竖线指示器 + 缩进层级 + 滚动高亮
 * CSS 变量颜色
 */
---

<nav class="card sticky top-20">
	<h3 class="card-title">目录</h3>
	<div id="toc-container" class="text-sm">
		<ul id="toc-list" class="space-y-1" style="border-left: 2px solid var(--color-border);" />
	</div>
</nav>

<script>
	(function () {
		const article = document.querySelector('article');
		const tocList = document.getElementById('toc-list');

		if (!article || !tocList) return;

		const headings = article.querySelectorAll('h2, h3');

		headings.forEach((heading) => {
			const id =
				heading.id ||
				heading.textContent
					?.toLowerCase()
					.replace(/[^\w\s-]/g, '')
					.replace(/\s+/g, '-') ||
				'';

			if (!heading.id) heading.id = id;

			const li = document.createElement('li');
			li.className = '-ml-[2px]';

			const a = document.createElement('a');
			a.href = `#${id}`;
			a.textContent = heading.textContent || '';
			a.style.cssText = `
				display: block;
				border-left: 2px solid transparent;
				padding: 0.25rem 0;
				padding-left: ${heading.tagName === 'H3' ? '1.5rem' : '0.75rem'};
				font-size: ${heading.tagName === 'H3' ? '0.75rem' : '0.875rem'};
				color: var(--color-text-secondary);
				text-decoration: none;
				transition: all 0.2s;
			`;

			a.dataset.tocLink = id;
			li.appendChild(a);
			tocList.appendChild(li);
		});

		// 滚动高亮
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					const id = entry.target.id;
					const link = tocList.querySelector(`a[data-toc-link="${id}"]`) as HTMLElement;
					if (link) {
						if (entry.isIntersecting) {
							tocList.querySelectorAll('a').forEach((a) => {
								(a as HTMLElement).style.borderLeftColor = 'transparent';
								(a as HTMLElement).style.color = 'var(--color-text-secondary)';
								(a as HTMLElement).style.fontWeight = 'normal';
							});
							link.style.borderLeftColor = 'var(--color-primary)';
							link.style.color = 'var(--color-primary)';
							link.style.fontWeight = '500';
						}
					}
				});
			},
			{ rootMargin: '-20% 0px -80% 0px' },
		);

		headings.forEach((h) => observer.observe(h));
	})();
</script>
