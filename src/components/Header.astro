---
/**
 * Header.astro — 顶部导航栏
 * 毛玻璃 + 固定顶部 + Logo + 内联搜索框
 * 搜索框聚焦时展开，失焦折叠为图标
 */
import { getProfile } from '../utils/userData';
import { navLinks } from '../../config/navConfig';
import { SITE_LOGO } from '../../config/siteConfig';
import ThemeToggle from './ThemeToggle.astro';
import { getPosts } from '../utils/userData';

const profile = getProfile();
const currentPath = Astro.url.pathname;
const logoPath = SITE_LOGO || profile.avatar;

// 搜索回退数据（开发模式用）
const searchData = getPosts().map(p => ({
	title: p.title, slug: p.slug,
	category: p.category || '', description: p.description,
}));
---

<header style="position: sticky; top: 0; z-index: 50; padding: 0.5rem 0;">
	<nav class="mx-auto flex max-w-[1500px] items-center justify-between gap-2 px-4 lg:px-6 py-3 rounded-2xl" style="background-color: var(--color-bg-nav); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid var(--color-border);">
		<!-- Logo + 站名（整个区域可点击跳转首页） -->
		<a href="/" class="flex items-center gap-2.5 text-lg font-bold no-underline shrink-0 transition-opacity hover:opacity-80" style="color: var(--color-text);">
			{logoPath && (
				<img src={logoPath} alt="Logo" class="h-7 w-7 rounded object-cover" style="box-shadow: 0 0 0 1px var(--color-border);" />
			)}
			{profile.name}
		</a>

		<!-- 导航链接 -->
		<div class="flex items-center gap-1">
			{navLinks.map(({ href, label }) => {
				const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
				return (
					<a
						href={href}
						class:list={[
							'nav-link rounded-lg px-3 py-1.5 text-base transition-all no-underline',
							isActive ? 'font-medium nav-link-active' : '',
						]}
						style={isActive
							? 'background-color: var(--color-primary-light); color: var(--color-primary);'
							: 'color: var(--color-text-secondary);'
						}
					>
						{label}
					</a>
				);
			})}
		</div>

		<!-- 搜索 + 主题切换 -->
		<div class="flex items-center gap-2">
			<!-- 内联搜索框 -->
			<div id="header-search" class="relative flex items-center">
				<svg class="absolute left-2.5 h-4 w-4 pointer-events-none" style="color: var(--color-text-secondary);" viewBox="0 0 20 20" fill="currentColor">
					<path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
				</svg>
				<input
					id="header-search-input"
					type="text"
					placeholder="搜索..."
					class="w-44 cursor-text rounded-lg border pl-8 pr-3 py-1.5 text-sm outline-none transition-all focus:w-56"
					style="background-color: var(--color-bg-card); border-color: var(--color-border); color: var(--color-text);"
					autocomplete="off"
				/>
				<!-- 下拉结果 -->
				<div id="header-search-results" class="absolute right-0 top-full mt-1 hidden w-72 rounded-xl p-2 shadow-lg" style="background-color: var(--color-bg-card); border: 1px solid var(--color-border); max-height: 60vh; overflow-y: auto;"></div>
			</div>
			<ThemeToggle />
		</div>
	</nav>
</header>

<script is:inline define:vars={{ searchFallback: searchData }}>
(function() {
	var input = document.getElementById('header-search-input');
	var results = document.getElementById('header-search-results');
	var timer;

	if (!input) return;

	function doSearch(q) {
		if (!q || !q.trim()) { results.classList.add('hidden'); return; }
		var keyword = q.toLowerCase();
		var data = searchFallback || [];
		var matched = data.filter(function(p) {
			return p.title.toLowerCase().includes(keyword) ||
				p.description.toLowerCase().includes(keyword) ||
				p.category.toLowerCase().includes(keyword);
		});
		if (matched.length === 0) {
			results.innerHTML = '<div class="py-4 text-center text-xs" style="color: var(--color-text-secondary);">没有结果</div>';
		} else {
			results.innerHTML = matched.slice(0, 8).map(function(p) {
				return '<a href="/blog/' + p.slug + '/" class="block rounded-lg px-3 py-2 text-sm no-underline transition-colors hover:bg-primary-light" style="color: var(--color-text);">' +
					p.title +
					(p.category ? ' <span class="text-xs" style="color: var(--color-text-secondary);">' + p.category + '</span>' : '') +
					'</a>';
			}).join('');
		}
		results.classList.remove('hidden');
	}

	input.addEventListener('focus', function() {
		if (input.value.trim()) doSearch(input.value);
	});

	input.addEventListener('blur', function() {
		setTimeout(function() { results.classList.add('hidden'); }, 200);
	});

	input.addEventListener('input', function() {
		clearTimeout(timer);
		timer = setTimeout(function() { doSearch(input.value); }, 250);
	});
})();
</script>

<style>
	.nav-link:hover {
		background-color: var(--color-primary-light);
		color: var(--color-primary) !important;
		transform: translateY(-1px);
	}
	.nav-link-active:hover {
		transform: none;
	}
</style>
