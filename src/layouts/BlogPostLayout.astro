---
/**
 * BlogPostLayout.astro — 文章详情布局
 * 标题上方显示阅读时间和字数统计（由 BaseLayout MutationObserver 驱动）
 * 右侧栏：站点统计 + 文章目录
 */
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SiteStats from '../components/SiteStats.astro';
import type { Post } from '../utils/userData';

interface Props {
	post: Post;
}

const { post } = Astro.props;
const usePixelFont = post.font === 'pixel';
---

<BaseLayout title={post.title} description={post.description}>
	<Fragment slot="main">
		<article class:list={[{ 'font-pixel-active': usePixelFont }]} class="card detail-card">
			<header class="mb-6 pb-5" style="border-bottom: 1px solid var(--color-border);">
				<div class="mb-3 flex items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
					<span>📖 <span id="reading-timer">00:00</span></span>
					<span style="color: var(--color-border);">·</span>
					<span id="word-count-display">...</span>
				</div>

				<h1 class="text-3xl font-bold sm:text-4xl" style="color: var(--color-text);">{post.title}</h1>

				<div class="mt-3 flex flex-wrap items-center gap-2 text-sm" style="color: var(--color-text-secondary);">
					<time><FormattedDate date={post.pubDate} /></time>
					{post.category && (
						<>
							<span style="color: var(--color-border);">·</span>
							<a href={`/archive?category=${encodeURIComponent(post.category)}`} class="no-underline hover:underline" style="color: var(--color-primary);">
								{post.category}
							</a>
						</>
					)}
					{post.tags && post.tags.length > 0 && post.tags.map((t) => (
						<>
							<span style="color: var(--color-border);">·</span>
							<a href={`/archive?tag=${encodeURIComponent(t)}`} class="no-underline hover:underline" style="color: var(--color-text-secondary);">
								#{t}
							</a>
						</>
					))}
				</div>
			</header>

			<div class="prose max-w-none">
				<slot />
			</div>
		</article>
	</Fragment>

	<Fragment slot="right-sidebar">
		<SiteStats />
		<slot name="toc" />
	</Fragment>
</BaseLayout>
