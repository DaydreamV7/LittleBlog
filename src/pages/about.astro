---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAboutPage } from '../utils/userData';
import { site } from '../../config';

const aboutPage = getAboutPage();
const title = aboutPage?.frontmatter.title || '关于';
const description = aboutPage?.frontmatter.description || '关于这个博客';
const AboutContent = aboutPage?.mod.default;
---

<BaseLayout title={`${title} | ${site.SITE_TITLE}`} description={description as string}>
	<Fragment slot="main">
		<div class="card overflow-hidden">
			{AboutContent ? (
				<div class="prose max-w-none">
					<AboutContent />
				</div>
			) : (
				<div>
					<h1 style="color: var(--color-text);">{title}</h1>
					<p style="color: var(--color-text-secondary);">创建 <code>user/pages/about.md</code> 来添加关于页面内容。</p>
				</div>
			)}
		</div>
	</Fragment>
</BaseLayout>
